<!DOCTYPE html>
<html>
<head>
<title>TikTok - NAFXY</title>

<style>
body{
    background:#0f0f0f;
    color:white;
    text-align:center;
    font-family:Arial;
}

.container{
    display:flex;
    justify-content:center;
    gap:20px;
    margin-top:40px;
    flex-wrap:wrap;
}

.box{
    width:320px;
    padding:20px;
    background:#1a1a1a;
    border-radius:15px;
    box-shadow:0 0 20px red;
}

input, button{
    width:100%;
    padding:10px;
    margin-top:10px;
    border:none;
    border-radius:10px;
}

button{
    background:red;
    color:white;
    cursor:pointer;
}

video, audio{
    width:100%;
    margin-top:10px;
}
</style>
</head>

<body>

<h1>𝐍𝐀𝐅𝐗𝐘 - TIKTOK</h1>

<div class="container">

<!-- VIDEO -->
<div class="box">
<h3>TikTok Downloader</h3>

<form method="POST">
<input name="url" placeholder="Paste link TikTok...">
<button name="type" value="video">Generate</button>
</form>

{% if video_url %}
<video controls>
<source src="{{ video_url }}">
</video>
<a href="{{ video_url }}"><button>Download Video</button></a>
{% endif %}
</div>

<!-- MP3 -->
<div class="box">
<h3>TikTok to MP3</h3>

<form method="POST">
<input name="url" placeholder="Paste link TikTok...">
<button name="type" value="mp3">Generate</button>
</form>

{% if music_url %}
<audio controls>
<source src="{{ music_url }}">
</audio>
<a href="{{ music_url }}"><button>Download MP3</button></a>
{% endif %}
</div>

</div>

</body>
</html>
